<Window x:Class="MarmaladeApp.View.Windows.MarmaladeBoxInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarmaladeApp.View.Windows"
        mc:Ignorable="d"
        Title="MarmaladeBoxInfoWindow" Height="450" Width="350" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="30" Background="White" BorderBrush="Black" BorderThickness="3" Padding="10">
        <Grid x:Name="InfoGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Grid.Row="0" CornerRadius="60" BorderBrush="Black" BorderThickness="1" Height="100" Width="100" Grid.ColumnSpan="3">
                <Border.Background>
                    <ImageBrush ImageSource="/Roaming/МармеладПингвины.jpg"/>
                </Border.Background>
            </Border>
            <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                <TextBlock Height="30" Name="NameBoxTB" Text="{Binding Name}"/>
                <TextBlock Height="30" x:Name="MarmaladeName1TB" TextWrapping="Wrap" MouseLeftButtonDown="MarmaladeName1TB_MouseLeftButtonDown"/>
                <TextBlock Height="30" x:Name="MarmaladeName2TB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeName3TB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeName4TB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeBoxCostTB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeGrammTB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeHalalTB" TextWrapping="Wrap"/>
                <TextBlock Height="Auto" x:Name="MarmaladeCompoundTB" TextWrapping="Wrap"/>
                <TextBlock Height="30" x:Name="MarmaladeEnergyTB" TextWrapping="Wrap"/>
            </StackPanel>
            <Button Height="40" Content="Закрыть" x:Name="CloseBtn" Click="CloseBtn_Click" Grid.Column="2" Grid.Row="20" />
            <Button Height="40" Content="Купить" x:Name="BuyBtn" Click="BuyBtn_Click" Grid.Column="0" Grid.Row="20"/>
        </Grid>
    </Border>
</Window>

