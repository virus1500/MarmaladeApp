<Page x:Class="MarmaladeApp.View.Pages.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MarmaladeApp.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TicketPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SerachTB" TextChanged="SerachTB_TextChanged"/>
        </Grid>

        <DataGrid x:Name="InfoDG" Grid.Row="3" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин пользователя" Binding="{Binding User.Login}"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding DateOrder}"/>
                <DataGridTextColumn Header="Выполнен ли заказ" Binding="{Binding OrderCompleted}"/>
                <DataGridTextColumn Header="Дата выполнения" Binding="{Binding DateComplete}"/>
                <DataGridTextColumn Header="Отказан ли заказ" Binding="{Binding CanceledTicket}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
