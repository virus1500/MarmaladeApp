<Page x:Class="MarmaladeApp.View.Pages.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MarmaladeApp.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderPage">

    <Grid x:Name="InfoGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>


        <DataGrid x:Name="InfoDG" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Содержимое заказа" Binding="{Binding Name}" x:Name="ItemsDGC"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="1" Text="Сумма" x:Name="SumTBl"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>
            <Button Content="Заказать" Grid.Column="0" Name="CreateTicketBtn" Click="CreateTicketBtn_Click"/>
            <Button Content="Удалить" Grid.Column="2" Name="DelItemBtn" Click="DelItemBtn_Click"/>
            <Button Content="Очистить" Grid.Column="4" Name="ClearTicketBtn" Click="ClearTicketBtn_Click"/>
        </Grid>
    </Grid>
</Page>
